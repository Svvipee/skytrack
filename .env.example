# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# OAuth Providers (optional - app works without these)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OpenSky Network (optional - increases rate limits when authenticated)
OPENSKY_USERNAME=your-opensky-username
OPENSKY_PASSWORD=your-opensky-password

# AviationStack API (optional - enriches flight metadata)
AVIATIONSTACK_API_KEY=your-aviationstack-key

# AeroDataBox API via RapidAPI (optional - aircraft/airport enrichment)
AERODATABOX_API_KEY=your-aerodatabox-rapidapi-key
